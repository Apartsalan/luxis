# Luxis productie — kopieer naar .env en vul echte waarden in.
# Welke vars de backend verwacht: zie docker-compose.prod.yml (backend.environment).

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://luxis:CHANGE_ME_STRONG_PASSWORD@db:5432/luxis
POSTGRES_USER=luxis
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=luxis

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── Auth ──────────────────────────────────────────────────────────────────────
# Genereer met: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_SECRET_KEY
# Aparte sleutel voor OAuth-token-encryptie (Fernet). Valt terug op SECRET_KEY
# als leeg. Een eigen key laat je SECRET_KEY roteren zonder mailtokens te breken.
# LET OP: deze key WIJZIGEN maakt alle opgeslagen OAuth-tokens onbruikbaar →
# Outlook opnieuw koppelen. Genereer met: openssl rand -base64 48
TOKEN_ENCRYPTION_KEY=CHANGE_ME_GENERATE_RANDOM_TOKEN_KEY
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
CORS_ORIGINS=https://luxis.kestinglegal.nl
DOMAIN=luxis.kestinglegal.nl

# ── E-mail (SMTP-brug, F11) ───────────────────────────────────────────────────
# Tijdelijke uitgaande brug; M365/Graph is de eindoplossing (zie hieronder).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_USE_TLS=true

# ── Microsoft 365 / Graph (Outlook-integratie, M1-M6) ─────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://luxis.kestinglegal.nl/api/email/oauth/callback/outlook

# ── Google (legacy GmailProvider — niet meer gebruikt; leeg laten) ────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ── AI (Anthropic — 100% Claude sinds S159) ───────────────────────────────────
ANTHROPIC_API_KEY=

# ── Sentry (error-tracking, optioneel) ────────────────────────────────────────
# Gratis account op sentry.io → DSN hier. Leeg = geen tracking.
SENTRY_DSN=

# ── Compose (optioneel gemak) ─────────────────────────────────────────────────
# Zet de default compose-bestanden zodat `docker compose` zonder -f werkt.
COMPOSE_FILE=docker-compose.yml:docker-compose.prod.yml
