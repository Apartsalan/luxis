# Database
DATABASE_URL=postgresql+asyncpg://luxis:luxis_dev_password@db:5432/luxis

# Redis
REDIS_URL=redis://redis:6379/0

# Auth
SECRET_KEY=change-this-to-a-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_ENV=development
APP_DEBUG=true

# Google OAuth (Gmail API integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/email/oauth/callback

# Microsoft 365 / Outlook (Graph API integration)
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://luxis.kestinglegal.nl/api/email/oauth/callback/outlook

# Sentry (optional, leave empty to disable)
SENTRY_DSN=

# Frontend — uses relative URLs, Next.js rewrites proxy /api/* to backend
# Set BACKEND_URL only if backend is not at http://backend:8000 (Docker default)
# BACKEND_URL=http://localhost:8000
