# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://luxis:CHANGE_ME_STRONG_PASSWORD@db:5432/luxis
POSTGRES_USER=luxis
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=luxis

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_SECRET_KEY
# Optional: custom Fernet salt for OAuth token encryption (changing invalidates stored tokens)
# FERNET_SALT=generate-a-random-salt
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
CORS_ORIGINS=https://luxis.kestinglegal.nl

# ── Sentry (optional) ────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Frontend ──────────────────────────────────────────────────────────────────
# Frontend uses relative URLs — Next.js rewrites proxy /api/* to backend:8000
DOMAIN=luxis.kestinglegal.nl
