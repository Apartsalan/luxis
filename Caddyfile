{$DOMAIN:luxis.kestinglegal.nl} {
    # Health check → backend (for uptime monitoring)
    handle /health {
        reverse_proxy backend:8000
    }

    # API requests → backend
    handle /api/* {
        # Reject oversized uploads at the edge (413) before they reach the
        # backend. The largest legitimate upload is a 50 MB case file; 55 MB
        # leaves room for multipart overhead. Without this, a huge body is
        # fully spooled + read by the backend before its own size check (SEC-6).
        request_body {
            max_size 55MB
        }
        reverse_proxy backend:8000
    }

    # Everything else → frontend
    handle {
        reverse_proxy frontend:3000
    }

    # Automatic HTTPS via Let's Encrypt
    tls {
        on_demand
    }

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        X-XSS-Protection "1; mode=block"
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        -Server
    }

    # Gzip compression
    encode gzip

    # Logging
    log {
        output file /data/access.log {
            roll_size 10mb
            roll_keep 5
        }
    }
}

app.bespokestaffingsolutions.nl {
    reverse_proxy 172.17.0.1:3100

    tls {
        on_demand
    }

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        -Server
    }

    encode gzip
}

# Bespoke Staffing MCP server. Added manually on the VPS (S<=160); committed in
# S161 so deploys stop aborting on the dirty Caddyfile and prod stays reproducible.
mcp.bespokestaffingsolutions.nl {
    reverse_proxy 172.17.0.1:3101

    tls {
        on_demand
    }

    header {
        X-Content-Type-Options nosniff
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        -Server
    }
}
