# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://luxis:CHANGE_ME_STRONG_PASSWORD@db:5432/luxis
POSTGRES_USER=luxis
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=luxis

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_SECRET_KEY
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
CORS_ORIGINS=https://luxis.kestinglegal.nl

# ── Sentry (optional) ────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Frontend ──────────────────────────────────────────────────────────────────
# ZONDER /api erachter — de frontend voegt /api/ zelf toe aan elke call
NEXT_PUBLIC_API_URL=https://luxis.kestinglegal.nl
DOMAIN=luxis.kestinglegal.nl
