REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_ENV=development
APP_DEBUG=true

# Google OAuth (Gmail API integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
